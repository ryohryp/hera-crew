# Local-native HERA model configuration
# (Cloud-level reasoning without cloud API)
MANAGER_MODEL=deepseek-r1:14b
CRITIC_MODEL=phi4:latest
THINKER_MODEL=gemma3:latest

# Ollama Settings
OLLAMA_NUM_PARALLEL=4
OLLAMA_BASE_URL=http://localhost:11434

# (Optional) For Cloud LLM mode (e.g., Gemini)
# GOOGLE_API_KEY=your_google_api_key_here
