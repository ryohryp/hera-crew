# HERA: Hybrid Edge-cloud Resource Allocation 設定テンプレート

# --- LLM モデル設定 (Ollama を使用する場合は 'ollama/モデル名' と記述) ---
# メインのオーケストレーター（要: Function Calling 対応）
MANAGER_MODEL=ollama/qwen2.5:14b
# 思考の品質チェック担当
CRITIC_MODEL=ollama/phi4:latest
# タスク分解・下書き担当
THINKER_MODEL=ollama/gemma3:latest

# --- Ollama 接続設定 ---
# Ollama サーバーのベースURL
OLLAMA_BASE_URL=http://localhost:11434
# 並列実行数（GPUリソースに応じて調整）
OLLAMA_NUM_PARALLEL=4

# --- CrewAI 設定 ---
# テレメトリを無効化
CREWAI_TELEMETRY=false
# OpenAI APIキーを使用しない場合は NA を指定（認証エラー回避用）
OPENAI_API_KEY=NA

# --- クラウドモデルを使用する場合 (任意) ---
# GOOGLE_API_KEY=YOUR_API_KEY
# MANAGER_MODEL=gemini/gemini-1.5-pro
