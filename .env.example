# Local-native HERA model configuration
# IMPORTANT: ollama/ prefix is required for Ollama models.
# Omitting it will cause authentication errors against the real OpenAI API.
MANAGER_MODEL=ollama/qwen2.5:14b
CRITIC_MODEL=ollama/phi4:latest
THINKER_MODEL=ollama/gemma3:latest

# Tool-calling model for the Manager agent (must support function calling)
# TOOL_CALLING_MODEL=ollama/qwen2.5:14b

# Ollama Settings
OLLAMA_NUM_PARALLEL=4
OLLAMA_BASE_URL=http://localhost:11434

# (Optional) For Cloud LLM mode (e.g., Gemini)
# MANAGER_MODEL=gemini/gemini-1.5-pro
# GOOGLE_API_KEY=your_google_api_key_here
