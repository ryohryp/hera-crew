# HERA: Hybrid Edge-cloud Resource Allocation 設定テンプレート

# --- LLM モデル設定 (Ollama を使用する場合は 'ollama/モデル名' と記述) ---
# メインのオーケストレーター（要: Function Calling 対応）
MANAGER_MODEL=ollama/qwen2.5:14b
# 思考の品質チェック担当
CRITIC_MODEL=ollama/phi4:latest
# タスク分解・下書き担当
THINKER_MODEL=ollama/gemma4:26b

# --- Ollama 接続設定 ---
# Ollama サーバーのベースURL
OLLAMA_BASE_URL=http://localhost:11434
# 並列実行数（GPUリソースに応じて調整）
OLLAMA_NUM_PARALLEL=4

# --- CrewAI / LiteLLM セーフティ設定 ---
# OpenAI API キーを要求させないためのダミー値
OPENAI_API_KEY=NA
# LiteLLM がモデルコスト取得のために OpenAI に接続するのを防ぐ
LITELLM_LOCAL_MODEL_COST_MAP=True
# サポートされていないパラメータを無視してエラーを防ぐ
LITELLM_DROP_PARAMS=True

# --- その他設定 ---
# テレメトリを無効化
CREWAI_TELEMETRY=false
OTEL_SDK_DISABLED=true

# --- クラウドモデルを使用する場合 (任意) ---
# GOOGLE_API_KEY=YOUR_API_KEY
# MANAGER_MODEL=gemini/gemini-1.5-pro
